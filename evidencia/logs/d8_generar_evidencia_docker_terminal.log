    healthcheck:
      test:
        - CMD-SHELL
        - 'mongosh --quiet --username lidia --password *** --authenticationDatabase admin --eval ''db.adminCommand({ ping: 1 }).ok'' | grep 1'
      timeout: 5s
      interval: 10s
      retries: 10
      start_period: 20s
    image: mongo:7
    networks:
      default: null
    ports:
      - mode: ingress
        target: 27017
        published: "27027"
        protocol: tcp
    volumes:
      - type: volume
        source: lidia_mongo_data
        target: /data/db
        volume: {}
  postgres:
    environment:
      POSTGRES_DASHBOARD_PASSWORD: ***
      POSTGRES_DB: proyecto_lidia
      POSTGRES_ETL_PASSWORD: ***
      POSTGRES_PASSWORD: ***
      POSTGRES_USER: lidia
    healthcheck:
      test:
