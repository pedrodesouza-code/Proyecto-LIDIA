# =============================================================================
# SINIA-UY — Variables de entorno para Docker Compose
# =============================================================================
# Copiar este archivo a docker/.env y ajustar las contraseñas
# NUNCA commitear el .env con contraseñas reales
# =============================================================================

# PostgreSQL
PG_SUPERUSER=postgres
PG_SUPERPASS=CAMBIAR
PG_DATABASE=sinia_uy
PG_USER=sinia_etl_user
PG_PASSWORD=CAMBIAR
PG_DASH_PASSWORD=CAMBIAR
PG_PORT=5432

# MongoDB
MONGO_ROOT_USER=mongo_admin
MONGO_ROOT_PASS=CAMBIAR
MONGO_DATABASE=sinia_uy
MONGO_USER=sinia_etl_user
MONGO_PASSWORD=CAMBIAR
MONGO_AUTH_SOURCE=admin
MONGO_PORT=27017

# NASA FIRMS API Key (obtener gratis en firms.modaps.eosdis.nasa.gov)
FIRMS_MAP_KEY=tu_api_key_aqui

# Datasets locales grandes (no versionados)
DIR_DATOS_EXTERNOS=/app/Proyecto-LIDIA/data
FIRMS_SHAPEFILE_PATH=/app/Proyecto-LIDIA/data/raw/firms/fire_archive_M-C61_740435.shp

# Nivel de logs
LOG_LEVEL=INFO
TIMEZONE=America/Montevideo
